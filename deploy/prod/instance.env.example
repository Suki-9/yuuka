# ==============================================================================
# Yuuka 本番(prod) インスタンス — 非機密の起動パラメータ（テンプレート）
#   cp instance.env.example instance.env して環境に合わせて編集する。
#   instance.env は .gitignore 済（環境依存のため）。機密は secret.key（別ファイル）。
#   ※ この値に "$" を含めないこと（compose が変数展開してしまうため）
# ==============================================================================

# compose プロジェクト名（コンテナ/ネットワーク/ボリュームの名前空間。他インスタンスと重複させない）
COMPOSE_PROJECT_NAME=yuuka-prod

# ホスト公開ポート（リバースプロキシ / Cloudflare Tunnel がこのポートへ接続する）
HOST_PORT=7854
# 公開バインドアドレス。トンネル/プロキシがホストLAN IPへ接続する場合は 0.0.0.0。
# 完全にローカル(127.0.0.1)からのみ受ける場合は 127.0.0.1（その場合プロキシ側も localhost を向ける）。
BIND_ADDR=0.0.0.0

# コンテナ実行ユーザー（ホストの data/ 所有者の uid:gid に合わせる。例: 1000:1000）
PUID=1000
PGID=1000

# 既存データを bind マウントするホスト側絶対パス（DB・スクショ・ブラウザプロファイル等を格納）
DATA_DIR=/absolute/path/to/yuuka/data
# このインスタンスの config.yaml への絶対パス（:ro マウント）
CONFIG_FILE=/absolute/path/to/yuuka/deploy/prod/config.yaml

# 配布 Windows exe（/api/desktop/download）に焼き込む公開 URL。
# 未設定ならローカル既定 http://127.0.0.1:7854 にフォールバックする。
YUUKA_API_BASE=https://yuuka.example.com
