# ==============================================================================
# Yuuka 開発(dev) インスタンス — 非機密の起動パラメータ（テンプレート）
#   cp instance.env.example instance.env して環境に合わせて編集する。
#   ※ この値に "$" を含めないこと（compose が変数展開してしまうため）
# ==============================================================================

COMPOSE_PROJECT_NAME=yuuka-dev

# ホスト公開ポート（本番 7854 等と衝突させない）
HOST_PORT=7855
# 開発はローカルのみで十分なため 127.0.0.1
BIND_ADDR=127.0.0.1

PUID=1000
PGID=1000

# dev 専用の空データディレクトリ（初回起動時に新規 DB が作られる）
DATA_DIR=/absolute/path/to/yuuka/deploy/dev/data
CONFIG_FILE=/absolute/path/to/yuuka/deploy/dev/config.yaml
