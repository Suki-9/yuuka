# ==============================================================================
# Yuuka - 環境変数（機密設定）
# このファイルを .env にコピーして使用します: cp .env.example .env
# .env は git 管理外です。systemd 等で直接環境変数を渡す場合は .env は不要です。
# ==============================================================================

# 保存時暗号化のマスターシークレット【必須】
# DBに保存する Discordトークン・APIキー・パスワードマネージャ等の暗号化に使う
# マスターシークレットです。未設定の場合は起動しません。
# 十分に長いランダム文字列を設定してください。 生成例: openssl rand -base64 48
YUUKA_ENCRYPTION_SECRET=

# YUUKA_ENCRYPTION_SECRET のローテーション用新キー。設定して起動すると全暗号化データが
# 新キーで再暗号化されます。完了後 YUUKA_ENCRYPTION_SECRET に新キーの値を設定し、この項目を
# 削除して再起動してください（手順は仕様書 §6.2.1 参照）。
# YUUKA_ENCRYPTION_SECRET_NEW=

# 外部公開URL（本番では必須）。OAuth redirect_uri・Webhook URL・Cookieのハードニング判定に
# 使用します。これが https:// で始まる場合、セッションCookieは常に Secure + __Host- 付きで発行され、
# 非Secure Cookieは受理されません。未設定だと OAuth は localhost 以外で動作しません。
# 例: BASE_URL=https://yuuka.example.com
# BASE_URL=

# 信頼するリバースプロキシのIP（カンマ区切り・任意）。設定した場合のみ、直前のpeerがこのリストに
# 含まれるリクエストの X-Forwarded-For からクライアント実IPを解決します（ログインのレート制限等）。
# 未設定時は接続元IP（socket.remoteAddress）のみを信頼します（XFFは偽装可能なため無視）。
# 例: TRUSTED_PROXIES=127.0.0.1,10.0.0.2
# TRUSTED_PROXIES=

# ─── シナプス認知アーキテクチャ（schema v10 / R0・R1。docs/architecture/architecture_v2.md §13） ───
# R0/R1 のコンポーネント（ツール実績記録・Rust エンジン・シナプス抽出・L2 想起・§10 メトリクス）は
# 常時有効です。Rust エンジンは dist/bin/yuuka-synapse 等（pnpm build / Docker ビルドで生成）が
# あれば起動し、不在・未起動・タイムアウト時のみ現行挙動（直近15件の生履歴注入）へ自動デグレードします。
# シナプス抽出はヒューリスティック（LLM コストゼロ）。以下はチューニング値のみ（有効/無効の切替は無し）。
# L2 想起(1st Hop KNN)の取得件数（既定 5）。
# SYNAPSE_RECALL_K=5
