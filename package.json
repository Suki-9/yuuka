{
  "name": "yuuka",
  "version": "1.0.0",
  "description": "Discord Gemini 秘書ボット",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "cargo build --release --manifest-path src/rust_crawler/Cargo.toml && mkdir -p dist/bin && cp src/rust_crawler/target/release/yuuka-crawler dist/bin/ && tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "better-sqlite3": "^11.8.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^25.1.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
