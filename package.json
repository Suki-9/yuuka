{
  "name": "yuuka",
  "version": "1.0.0",
  "description": "Discord Gemini 秘書ボット",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "cargo build --release --manifest-path src/rust_crawler/Cargo.toml && mkdir -p dist/bin dist/assets && cp src/rust_crawler/target/release/yuuka-crawler dist/bin/ && cp -r src/assets/. dist/assets/ && tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@napi-rs/canvas": "^1.0.0",
    "@node-rs/argon2": "^2.0.2",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.5.1",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^25.1.0",
    "redis": "^4.7.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
