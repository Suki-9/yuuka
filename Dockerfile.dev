# syntax=docker/dockerfile:1
# ==============================================================================
# Yuuka - ホットリロード開発イメージ
# TypeScript は tsx watch でリアルタイム再起動。src/ はホストからマウントする。
# Rust バイナリはイメージ内にビルド済み（dist/bin/ マウント不要）。
#
# 起動: deploy/instance.sh dev hot
# ==============================================================================

# ---- stage 1: Rust バイナリ ------------------------------------------------
FROM rust:1-bookworm AS rust-builder
WORKDIR /build/crawler
COPY src/rust_crawler/Cargo.toml src/rust_crawler/Cargo.lock ./
COPY src/rust_crawler/src ./src
RUN cargo build --release \
 && cp target/release/yuuka-crawler /yuuka-crawler

WORKDIR /build/synapse
COPY src/rust_synapse/Cargo.toml src/rust_synapse/Cargo.lock ./
COPY src/rust_synapse/src ./src
RUN cargo build --release \
 && cp target/release/yuuka-synapse /yuuka-synapse

# ---- stage 2: Node 開発環境 ------------------------------------------------
FROM node:24-bookworm

ENV PUPPETEER_SKIP_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium \
    TZ=Asia/Tokyo \
    NODE_ENV=development

WORKDIR /app

# Puppeteer 用 chromium + 日本語/絵文字フォント + TLS + tzdata
# + better-sqlite3 等のネイティブモジュールビルド用ツールチェーン
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      chromium \
      fonts-noto-cjk fonts-noto-color-emoji \
      ca-certificates libssl3 \
      tzdata \
      python3 make g++ \
 && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# 依存インストール（layer キャッシュのため package.json 変更時のみ再ビルド）
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# Rust バイナリをイメージに焼き込む（src/ はホストマウントで上書きされるが dist/bin/ は残る）
RUN mkdir -p dist/bin
COPY --from=rust-builder /yuuka-crawler dist/bin/yuuka-crawler
COPY --from=rust-builder /yuuka-synapse dist/bin/yuuka-synapse

# 実行ユーザ（compose の user=既定 uid1000=node）が書き込む先を用意する。
# data/ は compose のバインドマウント、scratch/ はバックアップ一時作業用。
# /app 直下に新規ディレクトリを作れるよう /app 自体も node 所有にしておく
# （node_modules/dist は root 所有のままで可＝読み取り/実行だけできればよい）。
RUN mkdir -p /app/data /app/scratch \
 && chown node:node /app /app/data /app/scratch

# tsx を直接起動する（pnpm / corepack を経由しない）。
#   理由: 実行ユーザ(uid1000=node)は、build 時(root)に activate した corepack の
#   pnpm 9 を引き継げない。その結果 corepack が最新 pnpm(11) を毎起動 DL し、
#   ① pnpm.overrides を無視 ② 実行前の依存チェックが read-only な /app へ書こうとして
#   EACCES → コンテナが無限再起動する。依存はビルド時に焼き込み済みで、実行時に
#   パッケージマネージャは不要（本番 runtime も node を直接起動している）。
# src/ はホストからマウント（tsx watch でホットリロード）。
CMD ["node_modules/.bin/tsx", "watch", "src/index.ts"]
