[Unit]
Description=Yuuka Voice Client - 音声対話クライアント (voice-client)
After=network.target yuuka.service
Wants=yuuka.service

[Service]
Type=simple
# ↓ 実行ユーザーとインストール先パスをお使いの環境に合わせて変更してください
User=youruser
SupplementaryGroups=audio
WorkingDirectory=/path/to/voice-client
ExecStart=/usr/local/bin/node dist/index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
